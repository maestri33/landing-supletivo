---
/**
 * Checador de elegibilidade — micro-conversão de qualificação.
 * Regras reais da LDB: 15 anos → Fundamental, 18 anos → Médio.
 * Progressive enhancement: sem JS o widget some e fica a linha estática.
 */
import CtaButton from './CtaButton.astro';
---

<section
  id="elegibilidade"
  class="elig section on-dark grain"
  aria-labelledby="elig-title"
  data-section="elegibilidade"
>
  <span class="elig-watermark" aria-hidden="true">18+</span>
  <div class="container narrow elig-inner">
    <p class="kicker elig-kicker" data-reveal>Elegibilidade</p>
    <h2 id="elig-title" data-reveal>Você já pode se matricular?</h2>
    <p class="elig-lead" data-reveal style="--d: 1">
      Pela lei, depende só da sua idade. Confere aí:
    </p>

    <div class="elig-widget elig-card">
      <div class="elig-options" role="group" aria-label="Selecione a sua faixa de idade">
        <!-- alvo principal com peso de CTA; demais faixas como secundários -->
        <button type="button" class="elig-btn elig-btn--primary" data-elig="18mais" aria-pressed="false">
          Tenho 18 anos ou mais
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>
        <div class="elig-secondary">
          <button type="button" class="elig-btn" data-elig="15a17" aria-pressed="false">
            15 a 17 anos
          </button>
          <button type="button" class="elig-btn" data-elig="lt15" aria-pressed="false">
            Menos de 15
          </button>
        </div>
      </div>

      <!-- cancela: levanta quando a resposta libera o caminho -->
      <div class="elig-gate" aria-hidden="true">
        <svg viewBox="0 0 170 84" fill="none">
          <rect x="12" y="16" width="11" height="58" rx="3" fill="#ffffff24"></rect>
          <rect x="7" y="70" width="21" height="7" rx="2.5" fill="#ffffff30"></rect>
          <g class="gate-arm">
            <rect x="18" y="21" width="138" height="12" rx="6" fill="var(--yellow)"></rect>
            <path d="M46 21h17l-11 12H35z" fill="var(--ink)" opacity="0.7"></path>
            <path d="M84 21h17l-11 12H73z" fill="var(--ink)" opacity="0.7"></path>
            <path d="M122 21h17l-11 12h-17z" fill="var(--ink)" opacity="0.7"></path>
            <circle cx="24.5" cy="27" r="4" fill="var(--ink)"></circle>
          </g>
        </svg>
      </div>

      <div class="elig-result" data-elig-result aria-live="polite"></div>

      <div class="elig-cta" data-elig-cta hidden>
        <CtaButton position="elegibilidade" />
      </div>
    </div>

    <!-- régua de idades: sempre visível (com ou sem JS) -->
    <div class="elig-ages" data-reveal style="--d: 3">
      <div class="age" data-age="15">
        <b>15</b>
        <span>anos completos<br />Ensino Fundamental</span>
      </div>
      <span class="age-sep" aria-hidden="true"></span>
      <div class="age" data-age="18">
        <b>18</b>
        <span>anos completos<br />Ensino Médio</span>
      </div>
    </div>
    <p class="elig-law">
      Idades mínimas definidas pela Lei nº 9.394/96 (LDB): 15 anos para o
      Ensino Fundamental e 18 para o Ensino Médio.
    </p>
  </div>
</section>

<script>
  import { track } from '../scripts/track';

  const ANSWERS: Record<string, { text: string; cta: boolean }> = {
    lt15: {
      text: 'Quase lá. A partir dos 15 anos você já pode concluir o Ensino Fundamental pela EJA. A vaga vai estar aqui te esperando.',
      cta: false,
    },
    '15a17': {
      text: '✓ Você já pode concluir o Ensino Fundamental agora — e, aos 18, destrava também o Ensino Médio.',
      cta: true,
    },
    '18mais': {
      text: '✓ Caminho livre: você pode concluir o Ensino Fundamental e o Médio, 100% online, começando hoje.',
      cta: true,
    },
  };

  // liga a escolha de idade à régua da lei: a faixa clicada acende o(s)
  // número(s) que ela destrava (15 = Fundamental, 18 = Médio)
  const UNLOCKS: Record<string, string[]> = {
    lt15: ['15'],
    '15a17': ['15'],
    '18mais': ['15', '18'],
  };

  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-elig]');
  const result = document.querySelector<HTMLElement>('[data-elig-result]');
  const ctaWrap = document.querySelector<HTMLElement>('[data-elig-cta]');
  const ages = document.querySelectorAll<HTMLElement>('[data-age]');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.elig ?? '';
      const answer = ANSWERS[key];
      if (!answer || !result || !ctaWrap) return;

      buttons.forEach((b) => b.setAttribute('aria-pressed', String(b === btn)));
      result.textContent = answer.text;
      result.classList.add('show');
      result.classList.toggle('ok', answer.cta);
      btn.closest('.elig-widget')?.classList.toggle('gate-open', answer.cta);
      ctaWrap.hidden = !answer.cta;

      const on = UNLOCKS[key] ?? [];
      ages.forEach((a) => a.classList.toggle('age--on', on.includes(a.dataset.age ?? '')));

      track('eligibility_check', { faixa: key });
    });
  });
</script>

<style>
  .elig {
    background:
      radial-gradient(46rem 26rem at 15% 100%, rgb(255 196 0 / 0.08), transparent 60%),
      var(--green-deep);
    color: var(--paper);
    text-align: center;
    overflow: clip;
  }

  #elig-title {
    font-size: var(--text-h2-sm);
  }

  /* watermark temático: a idade que destrava tudo. Recuado pro canto
     inferior direito e ATRÁS do conteúdo (z-index 0): não disputa mais
     com o "?" do título centralizado. */
  .elig-watermark {
    position: absolute;
    right: clamp(-0.5rem, 1vw, 1.5rem);
    bottom: clamp(1.5rem, 5vw, 3.5rem);
    z-index: 0;
    font-family: var(--font-display);
    font-size: clamp(4.5rem, 11vw, 8.5rem);
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 2px rgb(255 196 0 / 0.12);
    pointer-events: none;
    user-select: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .elig-watermark {
      animation: elig-wm 10s ease-in-out infinite;
    }
  }

  @keyframes elig-wm {
    50% {
      transform: translateY(-14px) rotate(2deg);
    }
  }

  .elig-kicker {
    color: var(--yellow);
  }

  .elig-lead {
    color: rgb(255 255 255 / 0.78);
    font-size: var(--text-lg);
    margin-top: 1rem;
  }

  /* sem JS: widget some, régua de idades responde a pergunta */
  :global(html:not(.js)) .elig-widget {
    display: none;
  }

  /* ficha de checagem: card editorial, levemente torto como os demais */
  .elig-card {
    margin-top: 2.4rem;
    background: linear-gradient(180deg, rgb(255 255 255 / 0.08), rgb(255 255 255 / 0.03));
    border: 1px solid rgb(255 255 255 / 0.16);
    border-radius: var(--radius-lg);
    padding: clamp(1.8rem, 4.5vw, 2.8rem) clamp(1.2rem, 4vw, 2.6rem) clamp(1.6rem, 4vw, 2.4rem);
    box-shadow: 0 26px 52px -28px rgb(0 0 0 / 0.55);
    rotate: -0.6deg;
  }

  @media (max-width: 720px) {
    .elig-card {
      rotate: 0deg;
    }
  }

  .elig-options {
    display: grid;
    justify-items: center;
    gap: 0.8rem;
  }

  .elig-secondary {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
  }

  .elig-btn.elig-btn--primary {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    background: var(--yellow);
    border-color: var(--yellow);
    color: var(--ink);
    font-size: clamp(1.02rem, 0.95rem + 0.4vw, 1.18rem);
    padding: 1em 2em;
    box-shadow: 0 12px 32px -12px rgb(255 196 0 / 0.55);
  }

  .elig-btn.elig-btn--primary:hover {
    border-color: var(--yellow);
  }

  .elig-btn.elig-btn--primary[aria-pressed='true'] {
    box-shadow:
      0 0 0 3px var(--green-deep),
      0 0 0 6px var(--paper);
  }

  .elig-secondary .elig-btn {
    font-size: 0.9rem;
    padding: 0.7em 1.3em;
  }

  .elig-btn {
    font: inherit;
    font-weight: 700;
    color: var(--paper);
    background: rgb(255 255 255 / 0.08);
    border: 1.5px solid rgb(255 255 255 / 0.25);
    border-radius: 999px;
    padding: 0.85em 1.6em;
    cursor: pointer;
    touch-action: manipulation;
    transition:
      background-color 0.2s var(--ease-out),
      border-color 0.2s var(--ease-out),
      transform 0.15s var(--ease-out);
  }

  .elig-btn:hover {
    border-color: var(--yellow);
    transform: translateY(-2px);
  }

  .elig-btn:focus-visible {
    outline: 3px solid var(--yellow);
    outline-offset: 3px;
  }

  /* estado selecionado não fica só na cor: borda escura + anel interno */
  .elig-btn[aria-pressed='true'] {
    background: var(--yellow);
    border-color: var(--ink);
    color: var(--ink);
    box-shadow: inset 0 0 0 2px rgb(11 18 32 / 0.35);
  }

  /* cancela de estrada: fechada por padrão; "caminho livre" levanta o braço */
  .elig-gate {
    width: clamp(150px, 20vw, 205px);
    margin: 1.9rem auto 0;
    opacity: 0.95;
  }

  .elig-gate svg {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .gate-arm {
    transform-box: view-box;
    transform-origin: 24.5px 27px;
  }

  .elig-widget.gate-open .gate-arm {
    transform: rotate(-58deg);
  }

  @media (prefers-reduced-motion: no-preference) {
    .gate-arm {
      transition: transform 0.65s var(--ease-stamp);
    }
  }

  .elig-result {
    min-height: 3.4em;
    margin-top: 1.6rem;
    font-size: var(--text-lg);
    font-weight: 700;
    max-width: 34ch;
    margin-inline: auto;
  }

  @media (prefers-reduced-motion: no-preference) {
    .elig-result.show {
      animation: elig-pop 0.45s var(--ease-stamp);
    }
  }

  @keyframes elig-pop {
    0% {
      opacity: 0;
      transform: translateY(10px) scale(0.97);
    }
    100% {
      opacity: 1;
      transform: none;
    }
  }

  .elig-result.ok {
    color: var(--yellow);
  }

  .elig-cta {
    margin-top: 1.4rem;
  }

  /* régua de idades: os dois números que importam, em escala editorial */
  .elig-ages {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: clamp(1.2rem, 4vw, 2.6rem);
    margin-top: 2.6rem;
    text-align: left;
  }

  .age {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.45rem 0.7rem;
    border-radius: 14px;
    transition:
      background-color 0.3s var(--ease-out),
      box-shadow 0.3s var(--ease-out);
  }

  /* acende quando a faixa de idade escolhida destrava esta etapa */
  .age--on {
    background: rgb(255 196 0 / 0.1);
    box-shadow: inset 0 0 0 1.5px rgb(255 196 0 / 0.55);
  }

  .age--on b {
    text-shadow: 0 0 18px rgb(255 196 0 / 0.45);
  }

  .age b {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.7rem, 6vw, 3.9rem);
    line-height: 1;
    color: var(--yellow);
  }

  .age span {
    font-size: 0.84rem;
    font-weight: 700;
    line-height: 1.35;
    color: rgb(255 255 255 / 0.78);
  }

  .age-sep {
    width: 10px;
    height: 10px;
    background: var(--yellow);
    clip-path: polygon(50% 0, 100% 50%, 50% 100%, 0 50%);
    opacity: 0.55;
  }

  .elig-law {
    margin-top: 1.5rem;
    font-size: 0.8rem;
    color: rgb(255 255 255 / 0.55);
    max-width: 46ch;
    margin-inline: auto;
  }
</style>
