---
/**
 * Bandeira-diploma: a bandeira do Brasil estilizada (losango + círculo +
 * check da marca) que desenrola e enrola como um diploma, em loop.
 * 100% SVG + CSS (clip-path/transform — compositor friendly), sem JS.
 * Reduced-motion: fica aberta, estática, com o check já desenhado.
 */
---

<div class="diploma-flag" aria-hidden="true">
  <svg viewBox="0 0 560 380" fill="none">
    <defs>
      <linearGradient id="df-sheet-g" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#007a52"></stop>
        <stop offset="1" stop-color="#00543a"></stop>
      </linearGradient>
      <linearGradient id="df-roll-g" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0" stop-color="#003d29"></stop>
        <stop offset="0.45" stop-color="#00875b"></stop>
        <stop offset="0.7" stop-color="#00543a"></stop>
        <stop offset="1" stop-color="#002e1f"></stop>
      </linearGradient>
    </defs>

    <!-- sombra projetada (cresce junto com o desenrolar) -->
    <ellipse class="df-shadow" cx="280" cy="358" rx="248" ry="13" fill="#0b1220"></ellipse>

    <!-- folha: bandeira estilizada -->
    <g class="df-sheet">
      <rect x="20" y="40" width="520" height="300" rx="12" fill="url(#df-sheet-g)"></rect>
      <rect
        x="34"
        y="54"
        width="492"
        height="272"
        rx="7"
        stroke="var(--yellow)"
        stroke-opacity="0.35"
        stroke-width="1.5"></rect>

      <path d="M280 78 L488 190 280 302 72 190Z" fill="var(--yellow)"></path>
      <circle cx="280" cy="190" r="70" fill="var(--blue)"></circle>
      <path
        class="df-check"
        d="M248 192l23 23 46-50"
        stroke="#ffffff"
        stroke-width="12"
        stroke-linecap="round"
        stroke-linejoin="round"
        pathLength="1"></path>

      <!-- brilho de papel -->
      <rect x="20" y="40" width="520" height="60" rx="12" fill="#ffffff" opacity="0.05"></rect>

      <!-- carimbo da marca: bate logo depois que a bandeira abre;
           por estar dentro de .df-sheet, enrola junto no clip -->
      <g class="df-stamp">
        <circle cx="462" cy="288" r="33" fill="none" stroke="var(--yellow)" stroke-width="2.2" stroke-opacity="0.95"></circle>
        <circle cx="462" cy="288" r="26.5" fill="none" stroke="var(--yellow)" stroke-width="1.4" stroke-dasharray="3 5.2" stroke-linecap="round" stroke-opacity="0.9"></circle>
        <path d="M462 273l12.5 12.5L462 298l-12.5-12.5Z" fill="none" stroke="var(--yellow)" stroke-width="2.4" stroke-linejoin="round"></path>
        <path d="M456.5 286l4 4 8-8.5" fill="none" stroke="var(--yellow)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path>
      </g>
    </g>

    <!-- rolo (viaja da esquerda pra direita ao desenrolar) -->
    <g class="df-roll">
      <rect x="10" y="46" width="42" height="288" rx="21" fill="url(#df-roll-g)"></rect>
      <ellipse cx="31" cy="60" rx="19" ry="9" fill="#002e1f"></ellipse>
      <ellipse cx="31" cy="60" rx="10" ry="4.5" fill="none" stroke="#e9efe9" stroke-width="2" stroke-opacity="0.6"></ellipse>
      <ellipse cx="31" cy="320" rx="19" ry="9" fill="#002e1f"></ellipse>
      <ellipse cx="31" cy="320" rx="10" ry="4.5" fill="none" stroke="#e9efe9" stroke-width="2" stroke-opacity="0.45"></ellipse>
      <!-- borda amarela da bandeira aparecendo no rolo -->
      <rect x="46" y="50" width="5" height="280" rx="2.5" fill="var(--yellow)" opacity="0.85"></rect>

      <!-- fita: só enquanto está enrolado -->
      <g class="df-ribbon">
        <rect x="2" y="168" width="58" height="42" rx="8" fill="var(--yellow)"></rect>
        <path d="M14 210l-12 26 20-9 9 11z" fill="#d9a400"></path>
        <path d="M48 210l12 26-20-9-9 11z" fill="#d9a400"></path>
        <circle cx="31" cy="189" r="8.5" fill="var(--ink)" opacity="0.85"></circle>
      </g>
    </g>
  </svg>
</div>

<style>
  .diploma-flag {
    filter: drop-shadow(0 18px 30px rgb(0 0 0 / 0.35));
  }

  .diploma-flag svg {
    width: 100%;
    height: auto;
    transform: rotate(-3.5deg);
  }

  .df-sheet,
  .df-roll,
  .df-shadow {
    transform-box: fill-box;
  }

  .df-stamp {
    transform-box: fill-box;
    transform-origin: center;
    transform: rotate(-8deg);
  }

  .df-shadow {
    opacity: 0.3;
    filter: blur(7px);
    transform-origin: left center;
  }

  /* ===== loop: pausado fechado → desenrola → aberto (check) → enrola ===== */
  @media (prefers-reduced-motion: no-preference) {
    .df-sheet {
      clip-path: inset(0 94% 0 0 round 12px);
      animation: df-clip 12s infinite;
    }

    .df-roll {
      animation: df-travel 12s infinite;
    }

    .df-shadow {
      transform: scaleX(0.14);
      animation: df-shadow 12s infinite;
    }

    .df-ribbon {
      animation: df-ribbon 12s infinite;
    }

    .df-check {
      stroke-dasharray: 1;
      stroke-dashoffset: 1;
      animation: df-check 12s infinite;
    }

    .df-stamp {
      opacity: 0;
      animation: df-stamp 12s infinite;
    }

    .diploma-flag {
      animation: df-float 7s ease-in-out infinite;
    }
  }

  @keyframes df-clip {
    0%,
    8% {
      clip-path: inset(0 94% 0 0 round 12px);
      animation-timing-function: cubic-bezier(0.5, 0.05, 0.2, 1);
    }
    40%,
    70% {
      clip-path: inset(0 0% 0 0 round 12px);
      animation-timing-function: cubic-bezier(0.6, 0, 0.4, 1);
    }
    96%,
    100% {
      clip-path: inset(0 94% 0 0 round 12px);
    }
  }

  @keyframes df-travel {
    0%,
    8% {
      transform: translateX(0);
      animation-timing-function: cubic-bezier(0.5, 0.05, 0.2, 1);
    }
    40%,
    70% {
      transform: translateX(488px);
      animation-timing-function: cubic-bezier(0.6, 0, 0.4, 1);
    }
    96%,
    100% {
      transform: translateX(0);
    }
  }

  @keyframes df-shadow {
    0%,
    8% {
      transform: scaleX(0.14);
      animation-timing-function: cubic-bezier(0.5, 0.05, 0.2, 1);
    }
    40%,
    70% {
      transform: scaleX(1);
      animation-timing-function: cubic-bezier(0.6, 0, 0.4, 1);
    }
    96%,
    100% {
      transform: scaleX(0.14);
    }
  }

  @keyframes df-ribbon {
    0%,
    9% {
      opacity: 1;
    }
    16%,
    88% {
      opacity: 0;
    }
    95%,
    100% {
      opacity: 1;
    }
  }

  @keyframes df-check {
    0%,
    44% {
      stroke-dashoffset: 1;
    }
    56%,
    68% {
      stroke-dashoffset: 0;
    }
    78%,
    100% {
      stroke-dashoffset: 1;
    }
  }

  /* batida seca: surge grande já visível e assenta com squash */
  @keyframes df-stamp {
    0%,
    45% {
      opacity: 0;
      transform: scale(1.7) rotate(-14deg);
    }
    46% {
      opacity: 1;
      transform: scale(1.55) rotate(-13deg);
    }
    50% {
      transform: scale(0.92) rotate(-7deg);
    }
    53% {
      transform: scale(1.05) rotate(-8.5deg);
    }
    56%,
    100% {
      opacity: 1;
      transform: scale(1) rotate(-8deg);
    }
  }

  @keyframes df-float {
    50% {
      transform: translateY(-9px);
    }
  }

  /* reduced-motion: aberta, estática, check desenhado */
  @media (prefers-reduced-motion: reduce) {
    .df-roll {
      transform: translateX(488px);
    }

    .df-ribbon {
      opacity: 0;
    }

    .df-shadow {
      transform: none;
    }
  }
</style>
