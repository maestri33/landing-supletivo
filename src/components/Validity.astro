---
/**
 * Seção — A validade, explicada. Autoridade HONESTA e verificável: o
 * mecanismo real que dá validade ao certificado (estudo → prova presencial →
 * documentação à Secretaria → certificado) + a LDB linkada no Planalto.
 *
 * Regra de copy (mantida): sem nome de instituição parceira, sem logo do
 * governo, sem brasão. Autoridade própria e verificável > autoridade emprestada.
 */
const steps = [
  {
    t: 'Você estuda 100% online',
    d: 'O conteúdo das duas etapas roda no celular, no seu ritmo — sem sala de aula, sem prazo apertado.',
  },
  {
    t: 'Faz a prova final presencial',
    d: 'Você escolhe o polo e o dia. É o único passo presencial — e é ele que oficializa tudo.',
  },
  {
    t: 'Assina, e a documentação vai ao Estado',
    d: 'No polo você assina a documentação, que é enviada à Secretaria de Educação do seu estado.',
  },
  {
    t: 'Recebe o certificado, válido no Brasil inteiro',
    d: 'Emitido por instituição credenciada ao MEC, com validade em todo o território nacional.',
  },
];
---

<section
  id="validade"
  class="validity section on-dark grain"
  aria-labelledby="validity-title"
  data-section="validade"
>
  <div class="container">
    <p class="kicker validity-kicker" data-reveal>Como funciona a validade</p>
    <h2 id="validity-title" data-reveal>Como o seu certificado ganha validade</h2>
    <p class="validity-lead" data-reveal style="--d: 1">
      Sem logo emprestado: o que dá validade é um processo previsto em lei.
      Veja o caminho — e confira você mesmo.
    </p>

    <ol class="validity-steps">
      {steps.map((s, i) => (
        <li class="vstep" data-reveal style={`--d: ${i + 1}`}>
          <span class="vstep-num" aria-hidden="true">{i + 1}</span>
          <div class="vstep-body">
            <h3 class="vstep-title">{s.t}</h3>
            <p class="vstep-desc">{s.d}</p>
          </div>
        </li>
      ))}
    </ol>

    <div class="validity-law" data-reveal>
      <svg class="law-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M12 3v18M5 7h14M7 21h10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
        <path d="M5 7l-2.5 6a3 3 0 0 0 5 0z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"></path>
        <path d="M19 7l-2.5 6a3 3 0 0 0 5 0z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"></path>
        <circle cx="12" cy="4" r="1.6" stroke="currentColor" stroke-width="1.8"></circle>
      </svg>
      <div class="law-text">
        <p class="law-head">Amparado pela Lei nº 9.394/96 (LDB)</p>
        <p class="law-body">
          A Educação de Jovens e Adultos está prevista nos
          <strong>artigos 37 e 38</strong>. O art. 38, § 1º fixa as idades
          mínimas: <strong>15 anos</strong> para o Ensino Fundamental e
          <strong>18 anos</strong> para o Médio.
        </p>
        <a
          class="law-link"
          href="https://www.planalto.gov.br/ccivil_03/leis/l9394.htm"
          target="_blank"
          rel="noopener noreferrer"
        >
          Ler a lei no portal do Planalto
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M14 5h5v5M19 5l-9 9M19 13v5a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1h5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
          <span class="sr-only">(abre em nova aba)</span>
        </a>
      </div>
    </div>

    <p class="validity-note" data-reveal>
      <strong>Como você confere o credenciamento:</strong> no ato da matrícula,
      dentro do app, você vê os dados e o credenciamento da instituição parceira
      responsável pela certificação.
    </p>
  </div>
</section>

<style>
  .validity {
    background:
      radial-gradient(46rem 26rem at 85% 0%, rgb(255 196 0 / 0.07), transparent 60%),
      var(--green-deep);
    color: var(--paper);
    overflow: clip;
  }

  .validity-kicker {
    color: var(--yellow);
  }

  #validity-title {
    font-size: var(--text-h2-sm);
  }

  .validity-lead {
    color: var(--muted-on-dark);
    font-size: var(--text-lg);
    max-width: 46ch;
    margin-top: 1.2rem;
  }

  /* caminho da validade: timeline numerada, linha ligando os passos */
  .validity-steps {
    list-style: none;
    margin: 2.8rem 0 0;
    padding: 0;
    display: grid;
    gap: 1.5rem;
    max-width: 46rem;
  }

  .vstep {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 1.1rem;
  }

  /* linha vertical ligando o número ao próximo passo */
  .vstep:not(:last-child)::before {
    content: '';
    position: absolute;
    left: 1.3rem;
    top: 2.6rem;
    bottom: -1.5rem;
    width: 2px;
    background: rgb(255 196 0 / 0.25);
    transform: translateX(-50%);
  }

  .vstep-num {
    flex: none;
    width: 2.6rem;
    height: 2.6rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    font-family: var(--font-display);
    font-size: 1.05rem;
    line-height: 1;
    color: var(--yellow);
    background: var(--green-deep);
    border: 2px solid rgb(255 196 0 / 0.55);
  }

  .vstep-body {
    padding-top: 0.15rem;
  }

  .vstep-title {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1.08rem;
    line-height: 1.3;
    letter-spacing: 0;
  }

  .vstep-desc {
    margin-top: 0.3rem;
    color: var(--muted-on-dark);
    font-size: 0.95rem;
  }

  /* card da lei: âncora verificável (link real pro Planalto) */
  .validity-law {
    margin-top: 2.6rem;
    display: flex;
    align-items: flex-start;
    gap: 1.1rem;
    max-width: 46rem;
    background: rgb(255 255 255 / 0.06);
    border: 1px solid rgb(255 255 255 / 0.16);
    border-radius: var(--radius);
    padding: 1.5rem 1.6rem;
  }

  .law-icon {
    flex: none;
    width: 2rem;
    height: 2rem;
    color: var(--yellow);
    margin-top: 0.1rem;
  }

  .law-head {
    font-weight: 700;
    font-size: 1.02rem;
  }

  .law-body {
    margin-top: 0.4rem;
    color: var(--muted-on-dark);
    font-size: 0.95rem;
  }

  .law-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.9rem;
    font-weight: 700;
    color: var(--yellow);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 2px;
  }

  .law-link svg {
    width: 1.05em;
    height: 1.05em;
  }

  .law-link:hover {
    color: var(--yellow-soft);
  }

  .validity-note {
    margin-top: 2rem;
    max-width: 50ch;
    font-size: 0.92rem;
    color: var(--muted-on-dark);
  }

  .validity-note strong {
    color: var(--paper);
  }

  @media (min-width: 720px) {
    .validity-law {
      padding: 1.7rem 1.9rem;
    }
  }
</style>
