---
/**
 * Seção 8b — Rodapé: logo, CNPJ (placeholder), links legais, aviso LGPD.
 */
import Logo from './Logo.astro';
import { COMPANY_URL, CAREERS_URL } from '../config';

const year = new Date().getFullYear();
---

<footer class="footer on-dark">
  <div class="container">
    <p class="footer-tag">
      Feito para quem decidiu <span>voltar a estudar.</span>
    </p>

    <div class="footer-top">
      <div class="footer-brand">
        <Logo variant="light" />
        <!-- bandeirinha tremulando: assinatura de fechamento -->
        <svg class="footer-flag" viewBox="0 0 84 64" fill="none" aria-hidden="true">
          <rect x="4" y="2" width="4" height="60" rx="2" fill="#ffffff2b"></rect>
          <circle cx="6" cy="3" r="3" fill="var(--yellow)"></circle>
          <g class="ff-cloth">
            <rect x="8" y="6" width="62" height="40" rx="4" fill="var(--green)"></rect>
            <path d="M39 12l22 14-22 14-22-14z" fill="var(--yellow)"></path>
            <circle cx="39" cy="26" r="8.5" fill="var(--blue)"></circle>
            <path d="M35.5 26.2l2.8 2.8 5.2-5.6" stroke="#fff" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path>
          </g>
        </svg>
      </div>
      <nav aria-label="Conteúdo e links legais" class="footer-nav">
        <div class="footer-nav-group">
          <p class="footer-nav-title">Guias</p>
          <a href="/supletivo-online/">Supletivo Online</a>
          <a href="/eja-a-distancia/">EJA a Distância</a>
          <a href="/terminar-ensino-medio/">Terminar o Ensino Médio</a>
        </div>
        <div class="footer-nav-group">
          <p class="footer-nav-title">Legal</p>
          <a href="/termos/">Termos de Uso</a>
          <a href="/privacidade/">Política de Privacidade</a>
        </div>
        <div class="footer-nav-group">
          <p class="footer-nav-title">Empresa</p>
          <a href={COMPANY_URL} target="_blank" rel="noopener noreferrer">
            Sobre a V7M<span class="sr-only"> (abre em nova aba)</span>
          </a>
          <a href={CAREERS_URL} target="_blank" rel="noopener noreferrer">
            Trabalhe conosco<span class="sr-only"> (abre em nova aba)</span>
          </a>
        </div>
      </nav>
      <a class="to-top" href="#hero" aria-label="Voltar ao topo">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 19V5m-6 6 6-6 6 6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>

    <div class="footer-legal">
      <p>Supletivo Brasil · CNPJ 48.811.016/0001-00 · contato@supletivo.net.br</p>
      <p>
        O Supletivo Brasil fornece o material didático e a preparação para a
        EJA. A certificação é emitida por instituição parceira credenciada ao
        MEC, com validade em todo o território nacional, nos termos da Lei nº
        9.394/96 (LDB).
      </p>
      <p>
        Respeitamos a sua privacidade: os dados informados na matrícula são
        usados apenas para a sua inscrição e comunicação sobre o curso,
        conforme a LGPD (Lei nº 13.709/2018).
      </p>
      <p class="footer-copy">© {year} Supletivo Brasil. Todos os direitos reservados.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--ink);
    color: var(--muted-on-dark);
    padding-block: 3.6rem 2.6rem;
    font-size: 0.86rem;
    /* faixa tricolor: assinatura da bandeira fechando a página */
    border-top: 5px solid transparent;
    border-image: linear-gradient(
        90deg,
        var(--green) 0 34%,
        var(--yellow) 34% 67%,
        var(--blue) 67% 100%
      )
      1;
  }

  /* tagline de fechamento — a única frase grande do rodapé */
  .footer-tag {
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 4vw, 2.6rem);
    line-height: 1.15;
    color: var(--paper);
    max-width: 17ch;
    margin-bottom: 2.4rem;
  }

  .footer-tag span {
    color: var(--yellow);
  }

  /* espaço para o sticky CTA não cobrir o rodapé no mobile */
  @media (max-width: 899px) {
    .footer {
      padding-bottom: 7rem;
    }
  }

  .footer-top {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.4rem;
    padding-bottom: 1.8rem;
    border-bottom: 1px solid rgb(255 255 255 / 0.12);
  }

  /* logo um degrau maior que o do header — assinatura de fechamento */
  .footer-top :global(.logo svg) {
    width: 40px;
    height: 40px;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 1.1rem;
  }

  /* bandeirinha no mastro, ondulando de leve */
  .footer-flag {
    width: 52px;
    height: auto;
    overflow: visible;
  }

  .ff-cloth {
    transform-box: view-box;
    transform-origin: 8px 26px;
  }

  @media (prefers-reduced-motion: no-preference) {
    .ff-cloth {
      animation: ff-wave 4.5s ease-in-out infinite;
    }
  }

  @keyframes ff-wave {
    0%,
    100% {
      transform: skewY(0deg);
    }
    30% {
      transform: skewY(2.4deg) scaleX(0.985);
    }
    65% {
      transform: skewY(-1.8deg);
    }
  }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.4rem clamp(2rem, 6vw, 4rem);
  }

  .footer-nav-group {
    display: grid;
    gap: 0.15rem;
    justify-items: start;
  }

  .footer-nav-title {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(255 255 255 / 0.5);
    margin-bottom: 0.35rem;
  }

  .footer-nav a {
    color: var(--paper);
    font-weight: 700;
    font-size: 0.92rem;
    text-decoration: none;
    /* área de toque ≥ 44px sem inflar o layout */
    display: inline-block;
    padding-block: 0.55rem;
    margin-block: -0.25rem;
  }

  .footer-nav a:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  /* voltar ao topo: eco do scroll-cue do hero */
  .to-top {
    width: 3rem;
    height: 3rem;
    flex: none;
    display: grid;
    place-items: center;
    color: var(--paper);
    border: 1.5px solid rgb(255 255 255 / 0.3);
    border-radius: 50%;
    transition:
      transform 0.2s var(--ease-out),
      border-color 0.2s var(--ease-out),
      color 0.2s var(--ease-out);
  }

  .to-top svg {
    width: 1.15rem;
    height: 1.15rem;
  }

  .to-top:hover {
    transform: translateY(-3px);
    border-color: var(--yellow);
    color: var(--yellow);
  }

  .to-top:focus-visible {
    outline: 3px solid var(--yellow);
    outline-offset: 3px;
  }

  .footer-legal {
    margin-top: 1.8rem;
    display: grid;
    gap: 0.7rem;
    max-width: 56ch;
  }

  .footer-copy {
    margin-top: 0.6rem;
  }
</style>
